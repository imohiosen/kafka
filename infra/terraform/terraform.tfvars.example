# Copy to terraform.tfvars and fill in. terraform.tfvars is gitignored.
hcloud_token        = "your-hetzner-cloud-api-token"
ssh_public_key_path = "~/.ssh/id_ed25519.pub"

# Lock this down to your own IP. Find it with: curl -s https://ifconfig.me
allowed_cidrs = ["YOUR.PUBLIC.IP.HERE/32"]

# Optional overrides:
# server_type = "cx32"
# location    = "fsn1"
