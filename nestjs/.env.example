# ============================================================================
#  NestJS Kafka workshop — environment / tuning knobs
#  Copy to `.env` and tweak. Restart the app for changes to take effect.
#  Each var maps to a Kafka config name (shown in comments) so you can carry
#  what you learn over to the Spring Boot app and the benchmark scripts.
# ============================================================================

# --- Connection (shared with the Spring Boot app + benchmarks) --------------
KAFKA_BOOTSTRAP_SERVERS=localhost:9092     # Kafka `bootstrap.servers`
KAFKA_CLIENT_ID=nestjs-workshop            # client.id (cosmetic; shows in broker logs)
KAFKA_TOPIC=workshop.events                # the shared topic — do not change
PORT=3000                                  # HTTP port for /produce

# --- Producer tuning --------------------------------------------------------
KAFKA_PRODUCER_ACKS=-1                      # acks  (-1 == "all", 1 == leader, 0 == none)
KAFKA_PRODUCER_LINGER_MS=5                  # ~ linger.ms (app-level batching window)
KAFKA_PRODUCER_BATCH_MESSAGES=5000         # ~ batch.size (flush after N buffered msgs)
KAFKA_PRODUCER_COMPRESSION=gzip            # compression.type: none|gzip|snappy|lz4|zstd
                                           #   (only gzip is built in; others need a codec pkg)
KAFKA_PRODUCER_IDEMPOTENT=false            # enable.idempotence (forces acks=-1, dedupes retries)

# --- Consumer tuning --------------------------------------------------------
KAFKA_GROUP_ID=nestjs-workshop             # group.id
KAFKA_CONSUMER_MIN_BYTES=1                  # fetch.min.bytes
KAFKA_CONSUMER_MAX_WAIT_MS=500             # fetch.max.wait.ms
KAFKA_CONSUMER_MAX_BYTES_PER_PARTITION=1048576  # max.partition.fetch.bytes (1 MiB)
KAFKA_CONSUMER_FROM_BEGINNING=true         # ~ auto.offset.reset (true=earliest, false=latest)
KAFKA_CONSUMER_AUTOCOMMIT_MS=5000          # auto.commit.interval.ms (auto-commit stays ON)
